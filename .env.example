# Copy to .env and adapt values:
# cp .env.example .env

# Required
HCLOUD_TOKEN=replace-with-hetzner-token
HCLOUD_REGION=nbg1

# Optional
KUBECONFIG=./kubeconfig.yaml
GRAFANA_ADMIN_PASSWORD=

# Default true (no PVCs) so deploy succeeds before CSI is fixed. Set false for durable TSDB / Grafana / Loki data.
MONITORING_USE_EPHEMERAL_STORAGE=true

# Hostnames for Ingress (DNS must point to: kubectl -n monitoring get svc ingress-nginx-controller).
# Placeholder *.example.com does not resolve to your cluster — use your domain or leave empty.
GRAFANA_HOST=
PROMETHEUS_HOST=
LOKI_HOST=

# Open Grafana at http://<load-balancer-IP>/ without DNS (HTTP only). Set true and rerun deploy.
MONITORING_UI_VIA_LB_IP=false

# Cert-manager / Let's Encrypt
ENABLE_CERT_MANAGER=false
ACME_EMAIL=platform@example.com
LETSENCRYPT_ISSUER=letsencrypt-staging
