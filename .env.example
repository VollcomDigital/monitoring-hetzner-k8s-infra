# Copy to .env and adapt values:
# cp .env.example .env

# Required
HCLOUD_TOKEN=replace-with-hetzner-token
HCLOUD_REGION=nbg1

# Optional
KUBECONFIG=./kubeconfig.yaml
GRAFANA_ADMIN_PASSWORD=

# Set true if Helm waits fail on Pending PVCs (disables Prometheus / Grafana / Loki PVCs; no durable TSDB).
MONITORING_USE_EPHEMERAL_STORAGE=false

# Hostnames for Ingress exposure
GRAFANA_HOST=grafana.example.com
PROMETHEUS_HOST=prometheus.example.com
LOKI_HOST=loki.example.com

# Cert-manager / Let's Encrypt
ENABLE_CERT_MANAGER=false
ACME_EMAIL=platform@example.com
LETSENCRYPT_ISSUER=letsencrypt-staging
