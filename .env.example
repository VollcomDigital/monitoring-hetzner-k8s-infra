# Copy to .env and adapt values:
# cp .env.example .env

# Required
HCLOUD_TOKEN=replace-with-hetzner-token
HCLOUD_REGION=nbg1

# Optional
KUBECONFIG=./kubeconfig.yaml
GRAFANA_ADMIN_PASSWORD=

# Default true (no PVCs) so deploy succeeds before CSI is fixed. Set false for durable TSDB / Grafana / Loki data.
MONITORING_USE_EPHEMERAL_STORAGE=true

# Hostnames for Ingress (DNS A/AAAA → ingress-nginx LB: kubectl -n monitoring get svc ingress-nginx-controller).
# Use FQDNs you own (e.g. grafana.mydomain.com). Do not use grafana.example.com / prometheus.example.com / loki.example.com
# unless you control that domain—those names will not reach your cluster. Leave empty to skip that Ingress.
GRAFANA_HOST=
PROMETHEUS_HOST=
LOKI_HOST=

# HTTP on the ingress LB IP without DNS: / Grafana, /prometheus/ Prometheus UI, /loki/ Loki API. Rerun deploy after change.
MONITORING_UI_VIA_LB_IP=false

# Optional: ExternalDNS (automated records for Ingress hosts). Cloudflare is wired in deploy-monitoring.sh.
# Set zone at Cloudflare, token with Zone:DNS:Edit + Zone:Zone:Read. Hetzner DNS is not native in external-dns.
ENABLE_EXTERNAL_DNS=false
EXTERNAL_DNS_PROVIDER=cloudflare
# Cloudflare zone name for ExternalDNS (must be a domain you manage there), e.g. mydomain.com
EXTERNAL_DNS_DOMAIN_FILTER=
CF_API_TOKEN=

# Optional: align naming with hetzner-k8s-boilerplate (informational / manual — deploy script uses vars above).
# DNS_PROVIDER=cloudflare
# HETZNER_DNS_TOKEN=

# Cert-manager / Let's Encrypt
ENABLE_CERT_MANAGER=false
# Required when ENABLE_CERT_MANAGER=true (real mailbox for Let's Encrypt).
ACME_EMAIL=
LETSENCRYPT_ISSUER=letsencrypt-staging
