          "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\",cluster=~\"$cluster\",namespace=~\"$namespace\"}[5m])) / sum(kube_pod_container_resource_requests{resource=\"cpu\",cluster=~\"$cluster\",namespace=~\"$namespace\"})",
