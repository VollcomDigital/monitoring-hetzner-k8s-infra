hcloud_token = "YOUR_HCLOUD_API_TOKEN"

cluster_name = "monitoring-k3s"
region       = "nbg1"

node_type  = "cpx31"
node_count = 2

control_plane_type = "cpx31"

ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"

# Optional network hardening (recommended in production)
# ssh_allowed_cidrs = ["203.0.113.10/32"]
# api_allowed_cidrs = ["203.0.113.10/32"]

labels = {
  project = "monitoring-platform"
  env     = "production"
}
